modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "OpenX Scanner"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "openx_test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Vulnerable App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Advanced Labs"

[[workflows.workflow]]
name = "OpenX Scanner"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pip install requests colorama tqdm && python openx.py --help"

[[workflows.workflow]]
name = "openx_test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pip install requests colorama tqdm && python openx.py --help"

[[workflows.workflow]]
name = "Vulnerable App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python vulnerable_app.py"
waitForPort = 5000

[[workflows.workflow]]
name = "Advanced Labs"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python advanced_labs.py"
waitForPort = 5001

[deployment]
run = ["sh", "-c", "pip install requests colorama tqdm && python openx.py --help"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000
